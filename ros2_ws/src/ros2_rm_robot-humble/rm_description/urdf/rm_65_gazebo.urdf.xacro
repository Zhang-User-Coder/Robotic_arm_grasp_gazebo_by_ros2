        ixx="0.0017261110801622"
        ixy="2.52746264980217E-06"
        ixz="-3.67690303614961E-05"
        iyy="0.00170987405835604"
        iyz="1.67996364994424E-06"
        izz="0.000904023422915791" />
    </inertial> -->
    <inertia
        ixx="0"
        ixy="0"
        ixz="0"
        iyy="0"
        iyz="0"
        izz="0" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find rm_description)/meshes/rm_65_arm/base_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="1 1 1 1" />
      </material>
    </visual>
