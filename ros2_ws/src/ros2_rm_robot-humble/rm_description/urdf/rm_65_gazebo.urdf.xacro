<!-- arg->property -->
<xacro:property name="link6_type" value="$(arg link6_type)" />
  <link
    name="base_link">
    <inertial>
      <origin
        xyz="-0.000433277303987328 -3.54664423471128E-05 0.0599427668933796"
        rpy="0 0 0" />
      <mass
        value="0.841070778135659" />
