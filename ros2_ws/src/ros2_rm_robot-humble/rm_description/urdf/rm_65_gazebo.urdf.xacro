    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="camera_connection" />
    <child link="camera" />
    <origin xyz="0.0 -0.045 0.0" rpy="0.0 -1.5708 0.0" />
  </joint>
  
